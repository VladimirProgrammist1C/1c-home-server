# =============================================================================
# .gitignore для 1C Home Server Infrastructure
# =============================================================================

# === УСТАНОВЛЕННЫЕ ПРОГРАММЫ (НЕ КОММИТИТЬ) ===
Git/
Mini AI 1C/
Tools/
VPN/
inetpub/

# === OLLAMA ===
AI/Ollama/bin/
AI/Ollama/models/
AI/Ollama/logs/

# === МЕДИА И ОБРАЗЫ ===
*.mp4
*.avi
*.mkv
*.iso
*.vhdx
*.vhd

# === ТЯЖЁЛЫЕ ФАЙЛЫ ===
*.exe
*.msi
*.zip
*.7z
*.gguf
*.bin
*.tar.bz2

# === ЛОГИ И ВРЕМЕННЫЕ ===
*.log
logs/
BACKUPS/
*.bak

# === СЕКРЕТЫ ===
.env
.env.local

# === 1С ФАЙЛЫ ===
*.cf
*.cfu
*.dt
1Cv8.1CD
1Cv8.Log

# === IDE ===
.vscode/
.idea/

# === WINDOWS ===
Thumbs.db
.DS_Store
desktop.ini

* text=auto

*.sh text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
*.yml text eol=lf
# PDF-версии документации
README.pdf
*.pdf
