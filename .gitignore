# =============================================================================
# .gitignore для 1C Home Server Infrastructure
# Версия: Final (AI-папка игнорируется)
# =============================================================================

# --- 1. Secrets & Environment ---
.env
.env.local
.env.backup
*.pem
*.key

# --- 2. Private Data (Timing & Summary are inside _Private) ---
_Private/

# --- 3. AI Sandbox & Models (17GB+) ---
# Исключаем целиком, чтобы не грузить репозиторий тяжелыми моделями
AI/
AI/Ollama/
gpt4all/
nomic/
*.gguf
*.bin
*.pth

# --- 4. Local Installed Programs (Not part of code) ---
Git/
"Mini AI 1C"/
Tools/
VPN/
inetpub/
Distrib/

# --- 5. Virtual Machines (Hyper-V) ---
VMs/
*.vhdx
*.vhd
*.avhdx
*.iso

# --- 6. 1C:Enterprise Specifics ---
# Backups & Logs
Backups/
BACKUPS/
*.bak
*.backup
logs/
Logs/

# Database & System files
*.1CD
1Cv8.Log
*.tmp
*.tmp~

# Compiled/Config files (Source code *.epf, *.cfe is allowed)
*.cf
*.cfu
*.dt

# --- 7. Docker ---
.docker/

# --- 8. System & IDE ---
.vscode/
.idea/
Thumbs.db
.DS_Store
desktop.ini
$RECYCLE.BIN/