# =============================================================================
# .gitignore для 1C Home Server Infrastructure
# =============================================================================

# =============================================================================
# 🔐 СЕКРЕТЫ И ПАРОЛИ (НЕ КОММИТИТЬ!)
# =============================================================================
.env
.env.local
.env.*.local
*.env.backup
.env.backup-*

#==============================================================================
# ПРИВАТНЫЕ ДОКУМЕНТЫ (НЕ КОММИТИТЬ!)
#==============================================================================
_Private/
*.private.md
*.local.md

# =============================================================================
# 🗄️ БЭКАПЫ И ДАННЫЕ (НЕ КОММИТИТЬ!)
# =============================================================================
Backups/
backups/
BACKUPS/
Logs/
logs/
*.log
*.bak
*.backup
*.backup2
*-backup-*
*.dump
*.sql
postgres-data-backup.tar.gz
docker-compose.yml.backup-*

# =============================================================================
# 💻 УСТАНОВЛЕННЫЕ ПРОГРАММЫ (НЕ КОММИТИТЬ!)
# =============================================================================
Git/
Tools/
VPN/
inetpub/
Mini AI 1C/

# =============================================================================
# 🤖 OLLAMA И AI МОДЕЛИ (НЕ КОММИТИТЬ!)
# =============================================================================
AI/Ollama/bin/
AI/Ollama/models/
AI/Ollama/logs/
*.gguf
*.bin

# =============================================================================
# 🐳 DOCKER (НЕ КОММИТИТЬ!)
# =============================================================================
.docker/
docker-data/

# =============================================================================
# 📦 ТЯЖЁЛЫЕ ФАЙЛЫ (НЕ КОММИТИТЬ!)
# =============================================================================
*.exe
*.msi
*.zip
*.7z
*.tar.bz2
*.iso
*.vhdx
*.vhd
*.mp4
*.avi
*.mkv

# =============================================================================
# 📝 1С ФАЙЛЫ (НЕ КОММИТИТЬ!)
# =============================================================================
*.cf
*.cfu
*.dt
1Cv8.1CD
1Cv8.Log
*.1CD
*.log

# =============================================================================
# 🛠️ IDE И РЕДАКТОРЫ (НЕ КОММИТИТЬ!)
# =============================================================================
.vscode/
.idea/
*.suo
*.user
*.swp
*.swn

# =============================================================================
# 🪟 WINDOWS (НЕ КОММИТИТЬ!)
# =============================================================================
Thumbs.db
.DS_Store
desktop.ini
$RECYCLE.BIN/
System Volume Information/

# =============================================================================
# 📄 PDF-ВЕРСИИ (ОПЦИОНАЛЬНО)
# =============================================================================
*.pdf
README.pdf

# =============================================================================
# ✅ ЧТО КОММИТИМ (явно разрешаем)
# =============================================================================
# Docker конфигурации
!Dockerfile
!docker-compose.yml
!*.yml

# Скрипты
!Scripts/

# Документация (кроме приватной)
!Docs/
!*.md
!README.md
!COMMANDS.md
!infrastructure-guide.md
# ⚠️ TIMING.md и SUMMARY.md НЕ включаем (приватные)

# Мониторинг (конфигурации)
!monitoring/
!monitoring/grafana/
!monitoring/prometheus/
!monitoring/grafana/provisioning/

# Shell скрипты с LF окончаниями
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
*.yml text eol=lf